TRI_LAYER_ENABLE = yes

# Enable VIA support (dynamic keymap over RAW HID)
VIA_ENABLE = yes

# Enable OLED displays
OLED_ENABLE = yes

# Enable RGB Matrix (72 LEDs total, 36 per side)
RGB_MATRIX_ENABLE = yes
RGBLIGHT_ENABLE = no

# Enable encoder support with VIA mapping
ENCODER_ENABLE = yes
ENCODER_MAP_ENABLE = yes

# Use shared userspace (OLED views/sprites)
USER_NAME := chaseddevelopment

# Enable WPM tracking for Luna animation
WPM_ENABLE = yes

